# ─────────────────────────────────────────────────────────────
# Contact form (app/api/contact/route.ts)
# Copy this file to `.env.local` for local dev and populate the
# same variables in the Vercel dashboard for production.
# ─────────────────────────────────────────────────────────────

# Resend API key — https://resend.com/api-keys
# Required. Without this, the /api/contact endpoint returns 503.
RESEND_API_KEY=

# Address the form sends FROM.
# - Dev / before you own a domain: use Resend's shared sandbox sender.
#   onboarding@resend.dev works immediately, no domain verification needed.
# - Production: swap to an address on a domain verified in Resend, e.g.
#   hello@yourdomain.dev. Required for professional-looking deliverability.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Inbox that receives the messages. If unset, falls back to
# constants/site.ts → SITE_EMAIL.
CONTACT_TO_EMAIL=

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
# The public site key is embedded in the browser bundle; the secret key
# stays server-side. The values below are Cloudflare's public "always
# passes" test keys — safe for local dev, MUST be replaced in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
